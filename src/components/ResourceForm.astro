---
import type { Category, Resource } from '../db/schema';
import { LANGUAGE_CONFIG, RESOURCE_TYPE_CONFIG } from '../lib/constants';

interface Props {
  action: 'create' | 'edit';
  initialData?: Partial<Resource>;
  categories: Category[];
  errors?: Record<string, string>;
}

const { action, initialData = {}, categories, errors = {} } = Astro.props;

// Parse tags if string
const tagsValue = initialData.tags
  ? (typeof initialData.tags === 'string' ? JSON.parse(initialData.tags) : initialData.tags)
  : [];
---

<form
    method="POST"
    action={action === 'create' ? '/api/resources' : `/api/resources/${initialData.id}`}
    class="flex flex-col gap-5"
>
  {/* Title */}
  <div class="flex flex-col gap-2">
    <label for="title" class="text-sm font-medium text-text">
      Título <span class="text-red-400">*</span>
    </label>
    <input
      type="text"
      id="title"
      name="title"
      required
      maxlength="200"
      value={initialData.title || ''}
      class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text placeholder-text-subtle focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all duration-200"
      placeholder="Nombre del canal, herramienta o recurso"
    />
    {errors.title && <span class="text-xs text-red-400">{errors.title}</span>}
  </div>

  {/* URL */}
  <div class="flex flex-col gap-2">
    <label for="url" class="text-sm font-medium text-text">
      URL <span class="text-red-400">*</span>
    </label>
    <input
      type="url"
      id="url"
      name="url"
      required
      maxlength="500"
      value={initialData.url || ''}
      class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text placeholder-text-subtle focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all duration-200"
      placeholder="https://..."
    />
    {errors.url && <span class="text-xs text-red-400">{errors.url}</span>}
  </div>

  {/* Description */}
  <div class="flex flex-col gap-2">
    <label for="description" class="text-sm font-medium text-text">
      Descripción
    </label>
    <textarea
      id="description"
      name="description"
      maxlength="1000"
      rows="3"
      class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text placeholder-text-subtle focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all duration-200 resize-none"
      placeholder="Breve descripción del contenido..."
    >{initialData.description || ''}</textarea>
    <span class="text-xs text-text-subtle">Máximo 1000 caracteres</span>
  </div>

  {/* Tags */}
  <div class="flex flex-col gap-2">
    <label for="tags" class="text-sm font-medium text-text">
      Tags
    </label>
    <input
      type="text"
      id="tags"
      name="tags"
      value={tagsValue.join(', ')}
      class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text placeholder-text-subtle focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all duration-200"
      placeholder="tutorial, advanced, patterns (separados por coma)"
    />
    <span class="text-xs text-text-subtle">Separados por coma</span>
  </div>

  {/* Row: Language + Type + Category */}
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    {/* Language */}
    <div class="flex flex-col gap-2">
      <label for="language" class="text-sm font-medium text-text">
        Idioma <span class="text-red-400">*</span>
      </label>
      <select
        id="language"
        name="language"
        required
        class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 cursor-pointer transition-all duration-200"
      >
        {Object.entries(LANGUAGE_CONFIG).map(([value, config]) => (
          <option value={value} selected={initialData.language === value}>
            {config.label}
          </option>
        ))}
      </select>
    </div>

    {/* Type */}
    <div class="flex flex-col gap-2">
      <label for="type" class="text-sm font-medium text-text">
        Tipo <span class="text-red-400">*</span>
      </label>
      <select
        id="type"
        name="type"
        required
        class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 cursor-pointer transition-all duration-200"
      >
        {Object.entries(RESOURCE_TYPE_CONFIG).map(([value, config]) => (
          <option value={value} selected={initialData.type === value}>
            {config.label}
          </option>
        ))}
      </select>
    </div>

    {/* Category */}
    <div class="flex flex-col gap-2">
      <label for="categoryId" class="text-sm font-medium text-text">
        Categoría <span class="text-red-400">*</span>
      </label>
      <select
        id="categoryId"
        name="categoryId"
        required
        class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 cursor-pointer transition-all duration-200"
      >
        <option value="">Seleccionar...</option>
        {categories.map(cat => (
          <option value={cat.id} selected={initialData.categoryId === cat.id}>
            {cat.name}
          </option>
        ))}
      </select>
    </div>
  </div>

  {/* Actions */}
  <div class="flex gap-3 justify-end pt-4 border-t border-border">
    <a
      href="/recursos"
      class="px-5 py-2.5 bg-surface-elevated hover:bg-overlay border border-border text-text rounded-lg transition-all duration-150 active:scale-[0.97] text-sm font-medium"
    >
      Cancelar
    </a>
    <button
      type="submit"
      class="px-6 py-2.5 bg-accent hover:bg-accent-hover text-white rounded-lg transition-all duration-150 active:scale-[0.97] text-sm font-semibold flex items-center gap-2"
    >
      {action === 'create' ? (
        <>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Crear recurso
        </>
      ) : (
        <>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Guardar cambios
        </>
      )}
    </button>
  </div>
</form>