---
import type { Category } from '../db/schema';
import { LANGUAGE_CONFIG, RESOURCE_TYPE_CONFIG } from '../lib/constants';

interface Props {
  categories: Category[];
  currentFilters: {
    categoryId?: number;
    language?: string;
    type?: string;
    tags?: string[];
    sort?: string;
  };
  allTags?: { tag: string; count: number }[];
}

const {
  categories,
  currentFilters,
  allTags = [],
} = Astro.props;

const languageOptions = Object.entries(LANGUAGE_CONFIG).map(([value, config]) => ({
  value,
  label: config.label,
}));

const typeOptions = Object.entries(RESOURCE_TYPE_CONFIG).map(([value, config]) => ({
  value,
  label: config.label,
}));

const sortOptions = [
  { value: 'alpha', label: 'A-Z' },
  { value: 'newest', label: 'Más reciente' },
  { value: 'oldest', label: 'Más antiguo' },
  { value: 'relevance', label: 'Relevancia' },
];

// Check if any filters are active (including tags and sort != alpha)
const hasActiveFilters =
  currentFilters.categoryId ||
  currentFilters.language ||
  currentFilters.type ||
  (currentFilters.tags && currentFilters.tags.length > 0) ||
  (currentFilters.sort && currentFilters.sort !== 'alpha');
---

<form method="GET" action="/recursos" class="flex flex-col gap-4" id="filter-form">
  <!-- Row 1: Select filters + Sort -->
  <div class="flex flex-wrap gap-2 items-center">
    <!-- Category filter chip -->
    <div class="relative group/category">
      <select
        name="categoryId"
        onchange="document.getElementById('filter-form').submit()"
        class="appearance-none pl-3 pr-8 py-2 bg-surface border border-border rounded-lg text-sm text-text-muted hover:text-text hover:border-border-bright cursor-pointer transition-all duration-150 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent-muted"
      >
        <option value="">Categoría</option>
        {categories.map(cat => (
          <option value={cat.id} selected={currentFilters.categoryId === cat.id}>
            {cat.name}
          </option>
        ))}
      </select>
      <!-- Dropdown arrow -->
      <div class="absolute inset-y-0 right-0 pr-2.5 flex items-center pointer-events-none">
        <svg class="w-4 h-4 text-text-subtle group-hover/category:text-text-muted transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </div>
    </div>

    <!-- Language filter chip -->
    <div class="relative group/language">
      <select
        name="language"
        onchange="document.getElementById('filter-form').submit()"
        class="appearance-none pl-3 pr-8 py-2 bg-surface border border-border rounded-lg text-sm text-text-muted hover:text-text hover:border-border-bright cursor-pointer transition-all duration-150 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent-muted"
      >
        <option value="">Idioma</option>
        {languageOptions.map(opt => (
          <option value={opt.value} selected={currentFilters.language === opt.value}>
            {opt.label}
          </option>
        ))}
      </select>
      <div class="absolute inset-y-0 right-0 pr-2.5 flex items-center pointer-events-none">
        <svg class="w-4 h-4 text-text-subtle group-hover/language:text-text-muted transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </div>
    </div>

    <!-- Type filter chip -->
    <div class="relative group/type">
      <select
        name="type"
        onchange="document.getElementById('filter-form').submit()"
        class="appearance-none pl-3 pr-8 py-2 bg-surface border border-border rounded-lg text-sm text-text-muted hover:text-text hover:border-border-bright cursor-pointer transition-all duration-150 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent-muted"
      >
        <option value="">Tipo</option>
        {typeOptions.map(opt => (
          <option value={opt.value} selected={currentFilters.type === opt.value}>
            {opt.label}
          </option>
        ))}
      </select>
      <div class="absolute inset-y-0 right-0 pr-2.5 flex items-center pointer-events-none">
        <svg class="w-4 h-4 text-text-subtle group-hover/type:text-text-muted transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </div>
    </div>

    <!-- Sort dropdown -->
    <div class="relative group/sort">
      <select
        name="sort"
        onchange="document.getElementById('filter-form').submit()"
        class="appearance-none pl-3 pr-8 py-2 bg-surface border border-border rounded-lg text-sm text-text-muted hover:text-text hover:border-border-bright cursor-pointer transition-all duration-150 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent-muted"
      >
        {sortOptions.map(opt => (
          <option value={opt.value} selected={currentFilters.sort === opt.value || (!currentFilters.sort && opt.value === 'alpha')}>
            {opt.label}
          </option>
        ))}
      </select>
      <div class="absolute inset-y-0 right-0 pr-2.5 flex items-center pointer-events-none">
        <svg class="w-4 h-4 text-text-subtle group-hover/sort:text-text-muted transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12" />
        </svg>
      </div>
    </div>

    <!-- Keep search query if exists -->
    {Astro.url.searchParams.has('q') && (
      <input type="hidden" name="q" value={Astro.url.searchParams.get('q')} />
    )}

    <!-- Clear all filters -->
    {hasActiveFilters && (
      <a
        href="/recursos"
        class="px-3 py-2 text-text-subtle hover:text-text text-sm transition-colors duration-150 flex items-center gap-1.5 hover:bg-surface rounded-lg"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
        Limpiar
      </a>
    )}
  </div>

  <!-- Row 2: Tag chips -->
  {allTags.length > 0 && (
    <div class="flex flex-wrap gap-2 items-center">
      <span class="text-xs text-text-subtle mr-1">Tags:</span>
      {allTags.map(({ tag, count }) => {
        const isSelected = currentFilters.tags?.includes(tag);
        return (
          <label
            class:list={[
              'tag-chip cursor-pointer transition-all duration-150 text-xs px-2.5 py-1 rounded-full border',
              isSelected
                ? 'bg-accent/20 border-accent text-accent'
                : 'bg-surface border-border text-text-muted hover:text-text hover:border-border-bright',
            ]}
          >
            <input
              type="checkbox"
              name="tags"
              value={tag}
              checked={isSelected}
              onchange="document.getElementById('filter-form').submit()"
              class="hidden"
            />
            <span>{tag}</span>
            <span class="text-text-subtle ml-0.5">({count})</span>
          </label>
        );
      })}
    </div>
  )}
</form>