---
import { RESOURCE_TYPE_CONFIG, TYPE_COLORS } from '../lib/constants';
import type { ResourceType } from '../lib/constants';

interface Props {
  type: ResourceType;
  size?: 'sm' | 'md';
}

const { type, size = 'sm' } = Astro.props;
const config = RESOURCE_TYPE_CONFIG[type] ?? RESOURCE_TYPE_CONFIG.video;
const colors = TYPE_COLORS[type] ?? TYPE_COLORS.video;

const sizeClasses = {
  sm: 'px-2 py-0.5 text-xs',
  md: 'px-2.5 py-1 text-sm',
};
---

<span
  class={`flex items-center gap-1.5 ${sizeClasses[size]} rounded border ${colors.bg} ${colors.text} ${colors.border}`}
>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={config.icon} />
  </svg>
  {config.label}
</span>