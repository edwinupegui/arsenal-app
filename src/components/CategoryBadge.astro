---
import { CATEGORY_ICON_MAP } from "../lib/constants";

interface Props {
    name: string;
    icon: string;
    size?: "sm" | "md";
}

const { name, icon, size = "sm" } = Astro.props;

const sizeClasses = {
    sm: "px-2 py-0.5 text-xs gap-1.5",
    md: "px-2.5 py-1 text-sm gap-2",
};

const iconPath =
    CATEGORY_ICON_MAP[icon as keyof typeof CATEGORY_ICON_MAP] ??
    CATEGORY_ICON_MAP.architect;
---

<span
    class={`inline-flex items-center rounded-md border ${sizeClasses[size]}`}
    style="background-color: oklch(0.48 0.015 60 / 0.08); border-color: oklch(0.48 0.015 60 / 0.20); color: oklch(0.68 0.018 60);"
>
    <svg
        class="w-3.5 h-3.5 opacity-70"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
    >
        <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d={iconPath}></path>
    </svg>
    {name}
</span>
