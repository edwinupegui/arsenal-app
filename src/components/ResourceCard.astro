---
import LanguageBadge from "./LanguageBadge.astro";
import TypeBadge from "./TypeBadge.astro";
import CategoryBadge from "./CategoryBadge.astro";
import TagList from "./TagList.astro";

interface Props {
    resource: {
        id: number;
        title: string;
        url: string;
        description?: string | null;
        tags?: string[] | string | null;
        language: string;
        type: string;
        categoryId: number;
        createdAt: string;
    };
    category: {
        id: number;
        name: string;
        icon: string;
    };
    /** Animation delay index for stagger effect */
    index?: number;
}

const { resource, category, index = 0 } = Astro.props;

// Parse tags if string
const tagsArray =
    typeof resource.tags === "string"
        ? JSON.parse(resource.tags || "[]")
        : resource.tags || [];

// Type-specific colors for visual distinction
const typeColors = {
    video: {
        border: "var(--color-type-video)",
        glow: "0.60 0.18 25",
        icon: "M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z",
    },
    article: {
        border: "var(--color-type-article)",
        glow: "0.62 0.14 220",
        icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
    },
    tool: {
        border: "var(--color-type-tool)",
        glow: "0.64 0.12 155",
        icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z",
    },
    repo: {
        border: "var(--color-type-repo)",
        glow: "0.82 0.06 70",
        icon: "M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4",
    },
};

const typeConfig =
    typeColors[resource.type as keyof typeof typeColors] || typeColors.video;
---

<article
    class="group relative bg-surface border border-border rounded-xl overflow-hidden transition-all duration-200 hover:border-border-bright hover:shadow-lg"
    data-type={resource.type}
    style={`--type-color: ${typeConfig.border}; --type-glow: ${typeConfig.glow};`}
>
    <!-- Top accent line that appears on hover -->
    <div
        class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-current to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
        style={`color: ${typeConfig.border};`}
    >
    </div>

    <div class="p-5 flex flex-col gap-4">
        <!-- Header row -->
        <div class="flex items-start gap-4">
            <!-- Type indicator icon -->
            <div
                class="shrink-0 w-10 h-10 rounded-lg flex items-center justify-center border transition-all duration-200 group-hover:scale-105"
                style={`background-color: oklch(${typeConfig.glow} / 0.1); border-color: oklch(${typeConfig.glow} / 0.30); color: oklch(${typeConfig.glow});`}
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d={typeConfig.icon}></path>
                </svg>
            </div>

            <!-- Title + URL -->
            <div class="flex-1 min-w-0">
                <h3
                    class="font-semibold text-text text-base leading-snug line-clamp-2 group-hover:text-accent transition-colors duration-150"
                >
                    <a
                        href={resource.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:underline decoration-accent/30"
                    >
                        {resource.title}
                    </a>
                </h3>
                <a
                    href={resource.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs text-text-subtle hover:text-text-muted transition-colors duration-150 flex items-center gap-1.5 mt-1.5 truncate group/link"
                >
                    <svg
                        class="w-3 h-3 shrink-0 opacity-60 group-hover/link:opacity-100 group-hover/link:text-accent transition-all duration-150"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                        ></path>
                    </svg>
                    <span class="truncate"
                        >{resource.url.replace(/^https?:\/\//, "")}</span
                    >
                </a>
            </div>
        </div>

        <!-- Description -->
        {
            resource.description && (
                <p class="text-sm text-text-muted leading-relaxed line-clamp-2">
                    {resource.description}
                </p>
            )
        }

        <!-- Badges row -->
        <div class="flex flex-wrap items-center gap-2 pt-1">
            <LanguageBadge language={resource.language} />
            <TypeBadge type={resource.type} />
            <CategoryBadge name={category.name} icon={category.icon} />

            <!-- Tags -->
            {
                tagsArray.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 ml-auto">
                        <TagList tags={tagsArray} maxVisible={3} />
                    </div>
                )
            }
        </div>
    </div>

    <!-- Hover overlay for depth (moved before actions so it doesn't dim them) -->
    <div
        class="absolute inset-0 bg-gradient-to-t from-surface/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none"
    >
    </div>

    <!-- Quick actions — reveal on hover with slide-up -->
    <div
        class="absolute bottom-0 left-0 right-0 px-4 pb-4 pt-8 bg-gradient-to-t from-surface via-surface/95 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-200 translate-y-1 group-hover:translate-y-0 z-10"
    >
        <div
            class="flex items-center justify-end gap-2 pt-3 border-t border-border/50"
        >
            <a
                href={`/recursos/${resource.id}/edit`}
                class="btn-press px-3 py-1.5 text-xs font-medium text-text-muted hover:text-text bg-surface-hover hover:bg-surface-elevated border border-border hover:border-border-bright rounded-lg transition-colors duration-150 flex items-center gap-1.5"
            >
                <svg
                    class="w-3.5 h-3.5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                    ></path>
                </svg>
                Editar
            </a>
            <form
                method="POST"
                action={`/api/resources/${resource.id}?_method=DELETE`}
                style="display: inline;"
            >
                <input type="hidden" name="_method" value="DELETE" />
                <button
                    type="submit"
                    class="btn-press px-3 py-1.5 text-xs font-medium text-danger hover:text-danger/80 bg-danger-bg/30 hover:bg-danger-bg/50 border border-danger/30 hover:border-danger/50 rounded-lg transition-colors duration-150 flex items-center gap-1.5"
                >
                    <svg
                        class="w-3.5 h-3.5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                        ></path>
                    </svg>
                    Papelera
                </button>
            </form>
        </div>
    </div>
</article>

<style>
    /* Type-specific glow on hover */
    article[data-type="video"]:hover {
        box-shadow: 0 0 24px oklch(0.60 0.18 25 / 0.15);
    }

    article[data-type="article"]:hover {
        box-shadow: 0 0 24px oklch(0.62 0.14 220 / 0.15);
    }

    article[data-type="tool"]:hover {
        box-shadow: 0 0 24px oklch(0.64 0.12 155 / 0.15);
    }

    article[data-type="repo"]:hover {
        box-shadow: 0 0 24px oklch(0.82 0.06 70 / 0.15);
    }

    /* Active state for button-like feel */
    article:active {
        transform: scale(0.99);
    }
</style>
