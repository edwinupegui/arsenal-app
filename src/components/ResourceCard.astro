---
import LanguageBadge from "./LanguageBadge.astro";
import TypeBadge from "./TypeBadge.astro";
import CategoryBadge from "./CategoryBadge.astro";
import TagList from "./TagList.astro";
import ConfirmDialog from "./ConfirmDialog.astro";
import {
    RESOURCE_TYPE_CONFIG,
    RESOURCE_TYPES,
    type ResourceType,
} from "../lib/constants";
import { authFetch } from "../lib/auth-interceptor";

interface Props {
    resource: {
        id: number;
        title: string;
        url: string;
        description?: string | null;
        tags?: string[] | string | null;
        language: string;
        type: string;
        categoryId: number;
        createdAt: string;
    };
    category: {
        id: number;
        name: string;
        icon: string;
    };
    /** Animation delay index for stagger effect */
    index?: number;
}

const { resource, category, index = 0 } = Astro.props;

// Parse tags - handles both Drizzle JSON arrays and legacy string format
const tagsArray = Array.isArray(resource.tags)
    ? resource.tags
    : typeof resource.tags === "string"
      ? JSON.parse(resource.tags || "[]")
      : [];

// OKLCH glow per resource type (drives accent line, icon tint and hover shadow).
const TYPE_GLOW: Record<ResourceType, string> = {
    video: "0.60 0.18 25",
    article: "0.62 0.14 220",
    tool: "0.64 0.12 155",
    repo: "0.82 0.06 70",
    course: "0.78 0.16 75",
    podcast: "0.72 0.18 350",
    newsletter: "0.74 0.13 200",
    community: "0.74 0.13 155",
};

function isResourceType(t: string): t is ResourceType {
    return (RESOURCE_TYPES as readonly string[]).includes(t);
}
const safeType: ResourceType = isResourceType(resource.type)
    ? resource.type
    : "video";
const typeIcon = RESOURCE_TYPE_CONFIG[safeType].icon;
const typeGlow = TYPE_GLOW[safeType];

const canEdit = Astro.locals.session != null;
---

<article
    class="group relative bg-surface border border-border rounded-xl overflow-hidden transition-all duration-200 hover:border-border-bright hover:shadow-lg"
    data-type={safeType}
    style={`--type-glow: ${typeGlow};`}
>
    <!-- Top accent line that appears on hover -->
    <div
        class="absolute top-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-current to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
        style={`color: oklch(${typeGlow});`}
    >
    </div>

    <div class="p-5 flex flex-col gap-4">
        <!-- Header row -->
        <div class="flex items-start gap-4">
            <!-- Type indicator icon -->
            <div
                class="shrink-0 w-10 h-10 rounded-lg flex items-center justify-center border transition-all duration-200 group-hover:scale-105"
                style={`background-color: oklch(${typeGlow} / 0.1); border-color: oklch(${typeGlow} / 0.30); color: oklch(${typeGlow});`}
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d={typeIcon}></path>
                </svg>
            </div>

            <!-- Title + URL -->
            <div class="flex-1 min-w-0">
                <h3
                    class="font-semibold text-text text-base leading-snug line-clamp-2 group-hover:text-accent transition-colors duration-150"
                >
                    <a
                        href={`/recursos/${resource.id}`}
                        class="hover:underline decoration-accent/30 relative z-10"
                    >
                        {resource.title}
                    </a>
                </h3>
                <span
                    class="text-xs text-text-subtle flex items-center gap-1.5 mt-1.5"
                >
                    <svg
                        class="w-3 h-3 shrink-0 opacity-60"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
                        ></path>
                    </svg>
                    <span class="truncate"
                        >{resource.url.replace(/^https?:\/\//, "")}</span
                    >
                </span>
            </div>
        </div>

        <!-- Description -->
        {
            resource.description && (
                <p class="text-sm text-text-muted leading-relaxed line-clamp-2">
                    {resource.description}
                </p>
            )
        }

        <!-- Badges row -->
        <div class="flex flex-wrap items-center gap-2 pt-1">
            <LanguageBadge language={resource.language} />
            <TypeBadge type={safeType} />
            <CategoryBadge name={category.name} icon={category.icon} />

            <!-- Tags -->
            {
                tagsArray.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 ml-auto">
                        <TagList tags={tagsArray} maxVisible={3} />
                    </div>
                )
            }
        </div>
    </div>

    <!-- Hover overlay for depth (moved before actions so it doesn't dim them) -->
    <div
        class="absolute inset-0 bg-linear-to-t from-surface/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none"
    >
    </div>

    {
        canEdit && (
            <div class="quick-actions absolute bottom-0 left-0 right-0 px-4 pb-4 pt-8 bg-linear-to-t from-surface via-surface/95 to-transparent transition-all duration-200 z-10">
                <div class="flex items-center justify-end gap-2 pt-3 border-t border-border/50">
                    <a
                        href={`/recursos/${resource.id}/edit`}
                        class="btn-press px-3 py-1.5 text-xs font-medium text-text-muted hover:text-text bg-surface-hover hover:bg-surface-elevated border border-border hover:border-border-bright rounded-lg transition-colors duration-150 flex items-center gap-1.5"
                    >
                        <svg
                            class="w-3.5 h-3.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                            />
                        </svg>
                        Editar
                    </a>
                    <button
                        type="button"
                        class="btn-press px-3 py-1.5 text-xs font-medium text-danger hover:text-danger/80 bg-danger-bg/30 hover:bg-danger-bg/50 border border-danger/30 hover:border-danger/50 rounded-lg transition-colors duration-150 flex items-center gap-1.5"
                        onclick={`openDeleteDialog(${resource.id})`}
                    >
                        <svg
                            class="w-3.5 h-3.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                            />
                        </svg>
                        Papelera
                    </button>

                    <ConfirmDialog
                        id={`delete-${resource.id}`}
                        title="Mover a papelera"
                        message="¿Querés mover este recurso a la papelera?"
                        confirmLabel="Mover a papelera"
                        cancelLabel="Cancelar"
                        variant="warning"
                    />
                </div>
            </div>
        )
    }
</article>

<style>
    /* Type-specific glow on hover, driven by --type-glow CSS var */
    article:hover {
        box-shadow: 0 0 24px oklch(var(--type-glow) / 0.15);
    }

    /* Active state for button-like feel */
    article:active {
        transform: scale(0.99);
    }

    /* Quick actions: hidden on hover-capable devices, always visible on touch */
    @media (hover: hover) and (pointer: fine) {
        .quick-actions {
            opacity: 0;
            transform: translateY(0.25rem);
        }
        article:hover .quick-actions,
        article:focus-within .quick-actions {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    import { authFetch } from "../lib/auth-interceptor";
    import { isOk } from "../lib/result";

    (window as any).openDeleteDialog = async (id: number) => {
        const confirmed = await (window as any).showConfirmDialog(
            `delete-${id}`,
        );
        if (!confirmed) return;

        const result = await authFetch(`/api/resources/${id}/delete`, {
            method: "POST",
            authContext: "Inicia sesión para mover el recurso a la papelera",
        });
        if (isOk(result)) {
            window.location.href = "/recursos?deleted=true";
        } else {
            (window as any).showError(
                result.error.message || "Error al eliminar",
            );
        }
    };
</script>
