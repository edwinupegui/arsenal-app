---
import Layout from "../../layouts/Layout.astro";
import ResourceCard from "../../components/ResourceCard.astro";
import SearchInput from "../../components/SearchInput.astro";
import FilterBar from "../../components/FilterBar.astro";
import { listResources, listCategories, getAllTags, parseTags, type SortOption } from "../../lib/resources";

const { searchParams } = Astro.url;
const q = searchParams.get("q") || "";
const categoryId = searchParams.get("categoryId")
    ? parseInt(searchParams.get("categoryId")!)
    : undefined;
const language = searchParams.get("language") || undefined;
const type = searchParams.get("type") || undefined;
const sort = (searchParams.get("sort") || 'alpha') as SortOption;
const tags = searchParams.getAll("tags").filter(t => t.length > 0) || undefined;

// Pagination params
const page = searchParams.get("page") ? parseInt(searchParams.get("page")!) : 1;
const limit = searchParams.get("limit") ? parseInt(searchParams.get("limit")!) : 20;

// Get all available tags for the filter UI
const tagsResult = getAllTags();
const allTags = tagsResult.ok ? tagsResult.value : [];

const resourcesResult = listResources(
    {
        q: q || undefined,
        categoryId,
        language,
        type,
        sort,
        tags,
    },
    page,
    limit
);
const categoriesResult = listCategories();

// Fallback to empty arrays if something went wrong
const resources = resourcesResult.ok ? resourcesResult.value.data : [];
const pagination = resourcesResult.ok ? resourcesResult.value.pagination : null;
const categories = categoriesResult.ok ? categoriesResult.value : [];

const resourcesWithCategory = resources.map((r) => {
    const category = categories.find((c) => c.id === r.categoryId);
    return {
        resource: r,
        category: category || {
            id: 0,
            name: "Uncategorized",
            icon: "bookmark",
        },
    };
});
---

<Layout
    title="Arsenal — Recursos"
    description="Gestor de recursos técnicos curados"
>
    <div class="flex flex-col gap-8">
        {/* Header */}
        <div
            class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4"
        >
            <div>
                <h1 class="text-2xl font-bold text-text tracking-tight">
                    Recursos
                </h1>
                <p class="text-text-muted text-sm mt-1">
                    {pagination
                        ? `${pagination.total} recurso${pagination.total !== 1 ? 's' : ''} — página ${pagination.currentPage} de ${pagination.totalPages}`
                        : `${resources.length} recurso${resources.length !== 1 ? 's' : ''} disponible${resources.length !== 1 ? 's' : ''}`}
                </p>
            </div>
        </div>

        {/* Search + Filters */}
        <form method="GET" action="/recursos" id="filter-form" class="flex flex-col gap-4">
            <SearchInput value={q} />
            <FilterBar
                categories={categories}
                currentFilters={{ categoryId, language, type, tags, sort }}
                allTags={allTags}
            />
        </form>

        {/* Results */}
        {
            resourcesWithCategory.length === 0 ? (
                <div class="flex flex-col items-center justify-center py-20 text-center animate-fade-up">
                    {/* Empty state illustration */}
                    <div class="relative mb-6 animate-float">
                        <div class="w-20 h-20 rounded-2xl bg-surface border border-border flex items-center justify-center">
                            <svg class="w-10 h-10 text-text-subtle" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </div>
                        {/* Decorative elements */}
                        <div class="absolute -top-2 -right-2 w-4 h-4 rounded-full border border-border opacity-50"></div>
                        <div class="absolute -bottom-1 -left-3 w-3 h-3 rounded-full bg-accent/20"></div>
                    </div>

                    <h3 class="text-text font-semibold text-lg mb-2">
                        {q ? `No encontramos "${q}"` : 'Sin recursos aún'}
                    </h3>
                    <p class="text-text-muted text-sm max-w-sm mb-6">
                        {q
                            ? 'Intenta con otros términos de búsqueda o explora todas las categorías'
                            : 'Comienza agregando tu primer recurso técnico a la colección'}
                    </p>

                    {q ? (
                        <a
                            href="/recursos"
                            class="px-4 py-2 text-accent hover:text-accent-hover text-sm font-medium transition-colors flex items-center gap-2"
                        >
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                            Limpiar búsqueda
                        </a>
                    ) : (
                        <a
                            href="/recursos/new"
                            class="btn-shimmer btn-press px-5 py-2.5 bg-accent hover:bg-accent-hover text-bg text-sm font-medium rounded-lg transition-colors duration-150 flex items-center gap-2"
                        >
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                            </svg>
                            Agregar recurso
                        </a>
                    )}
                </div>
            ) : (
                <>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 stagger-enter">
                    {resourcesWithCategory.map(({ resource, category }, index) => (
                        <div style={`animation-delay: ${Math.min(index * 60, 600)}ms`}>
                            <ResourceCard
                                resource={{
                                    ...resource,
                                    tags: parseTags(resource.tags),
                                }}
                                category={category}
                            />
                        </div>
                    ))}
                </div>

                {/* Pagination Controls */}
                {pagination && pagination.totalPages > 1 && (
                    <div class="flex items-center justify-center gap-4 mt-8">
                        <a
                            href={`/recursos?${new URLSearchParams({
                                ...Object.fromEntries(searchParams),
                                page: String(page - 1),
                            }).toString()}`}
                            class:list={[
                                "px-4 py-2 rounded-lg text-sm font-medium transition-colors",
                                pagination.hasPrev
                                    ? "bg-surface hover:bg-surface-hover border border-border text-text"
                                    : "bg-surface/50 border border-border/50 text-text-muted cursor-not-allowed opacity-50"
                            ]}
                            aria-disabled={!pagination.hasPrev}
                            tabindex={pagination.hasPrev ? undefined : -1}
                        >
                            ← Anterior
                        </a>
                        <span class="text-text-muted text-sm">
                            Página {pagination.currentPage} de {pagination.totalPages}
                        </span>
                        <a
                            href={`/recursos?${new URLSearchParams({
                                ...Object.fromEntries(searchParams),
                                page: String(page + 1),
                            }).toString()}`}
                            class:list={[
                                "px-4 py-2 rounded-lg text-sm font-medium transition-colors",
                                pagination.hasNext
                                    ? "bg-surface hover:bg-surface-hover border border-border text-text"
                                    : "bg-surface/50 border border-border/50 text-text-muted cursor-not-allowed opacity-50"
                            ]}
                            aria-disabled={!pagination.hasNext}
                            tabindex={pagination.hasNext ? undefined : -1}
                        >
                            Siguiente →
                        </a>
                    </div>
                )}
                </>
            )
        }
    </div>
</Layout>
