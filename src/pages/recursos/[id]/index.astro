---
import Layout from "../../../layouts/Layout.astro";
import CategoryBadge from "../../../components/CategoryBadge.astro";
import ConfirmDialog from "../../../components/ConfirmDialog.astro";
import ErrorModal from "../../../components/ErrorModal.astro";
import {
    getResourceById,
    getCategoryById,
    parseTags,
} from "../../../lib/resources";
import { RESOURCE_TYPE_CONFIG, LANGUAGE_CONFIG } from "../../../lib/constants";
import {
    formatDuration,
    formatPrice,
    formatCount,
    formatFrequency,
    getExternalLinkLabel,
    type CourseMetadata,
    type PodcastMetadata,
    type NewsletterMetadata,
    type CommunityMetadata,
} from "../../../lib/metadata";

const { id } = Astro.params;
if (!id || isNaN(parseInt(id))) {
    return Astro.redirect("/recursos");
}
const resourceId = parseInt(id);

const resourceResult = getResourceById(resourceId);

if (!resourceResult.ok || !resourceResult.value) {
    return Astro.redirect("/recursos?error=not-found");
}

const resource = resourceResult.value;

if (resource.deletedAt) {
    return Astro.redirect("/recursos/trash");
}

const categoryResult = getCategoryById(resource.categoryId);
const tags = parseTags(resource.tags);
const canEdit = Astro.locals.session != null;

const languageConfig =
    LANGUAGE_CONFIG[resource.language as keyof typeof LANGUAGE_CONFIG] ??
    LANGUAGE_CONFIG.EN;
const typeConfig =
    RESOURCE_TYPE_CONFIG[resource.type as keyof typeof RESOURCE_TYPE_CONFIG] ??
    RESOURCE_TYPE_CONFIG.video;

// Type colors for visual distinction
const typeColors = {
    video: { border: "0.60 0.18 25", glow: "0.60 0.18 25" },
    article: { border: "0.62 0.14 220", glow: "0.62 0.14 220" },
    tool: { border: "0.64 0.12 155", glow: "0.64 0.12 155" },
    repo: { border: "0.82 0.06 70", glow: "0.82 0.06 70" },
};

const typeStyle =
    typeColors[resource.type as keyof typeof typeColors] || typeColors.video;

const metadata = resource.metadata as Record<string, unknown> | null;

// Narrowed metadata views — cast via unknown so TS accepts the conversion.
// These are only valid when resource.type matches; the JSX gates each block
// on `resource.type === '...' && metadata`, so the non-null usage is safe.
const courseMeta = metadata as unknown as CourseMetadata;
const podcastMeta = metadata as unknown as PodcastMetadata;
const newsletterMeta = metadata as unknown as NewsletterMetadata;
const communityMeta = metadata as unknown as CommunityMetadata;

const externalLinkLabel = getExternalLinkLabel(resource.type, metadata);
---

<Layout
    title={`${resource.title} — Arsenal`}
    description={resource.description || `Recurso: ${resource.title}`}
>
    <div class="max-w-3xl mx-auto">
        <!-- Breadcrumb navigation -->
        <nav class="mb-8 flex items-center gap-2 text-sm animate-fade-left">
            <a
                href="/recursos"
                class="text-text-muted hover:text-text transition-colors duration-150 flex items-center gap-1.5 group"
            >
                <svg
                    class="w-4 h-4 transition-transform group-hover:-translate-x-0.5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 19l-7-7 7-7"></path>
                </svg>
                Recursos
            </a>
            <span class="text-text-subtle">/</span>
            <span class="text-text truncate max-w-50">{resource.title}</span>
        </nav>

        <!-- Main content card -->
        <article
            class="bg-surface border border-border rounded-2xl overflow-hidden animate-fade-up"
            style={`--type-border: oklch(${typeStyle.border}); --type-glow: oklch(${typeStyle.glow});`}
        >
            <!-- Header with accent line -->
            <div class="relative">
                <div
                    class="absolute top-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-current to-transparent opacity-30"
                    style={`color: oklch(${typeStyle.border});`}
                >
                </div>
                <div class="p-6 pb-5">
                    <div class="flex items-start gap-5">
                        <!-- Type icon -->
                        <div
                            class="shrink-0 w-14 h-14 rounded-xl flex items-center justify-center border"
                            style={`background-color: oklch(${typeStyle.border} / 0.12); border-color: oklch(${typeStyle.border} / 0.30); color: oklch(${typeStyle.border});`}
                        >
                            <svg
                                class="w-7 h-7"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d={typeConfig.icon}></path>
                            </svg>
                        </div>

                        <div class="flex-1 min-w-0">
                            <h1
                                class="text-2xl font-bold text-text tracking-tight leading-tight"
                            >
                                {resource.title}
                            </h1>
                            <a
                                href={resource.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-sm text-text-muted hover:text-accent transition-colors duration-150 flex items-center gap-2 mt-2 group/link"
                            >
                                <svg
                                    class="w-4 h-4 opacity-60 group-hover/link:opacity-100 group-hover/link:text-accent transition-all"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                                    ></path>
                                </svg>
                                <span class="truncate">{resource.url}</span>
                            </a>
                        </div>

                        <!-- Open link button -->
                        <a
                            href={resource.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="btn-press btn-shimmer px-5 py-2.5 bg-accent hover:bg-accent-hover text-bg text-sm font-medium rounded-xl transition-all duration-150 flex items-center gap-2 shadow-sm hover:shadow-glow-sm shrink-0"
                        >
                            {externalLinkLabel}
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                                ></path>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Description -->
            {
                resource.description && (
                    <div class="px-6 py-5 border-t border-border">
                        <p class="text-text leading-relaxed">
                            {resource.description}
                        </p>
                    </div>
                )
            }

            {/* Type-specific metadata section */}
            {
                metadata && Object.keys(metadata).length > 0 && (
                    <div class="px-6 py-5 border-t border-border bg-surface-subtle/30">
                        {resource.type === "course" && (
                            <div class="space-y-4">
                                <h3 class="text-sm font-semibold text-text uppercase tracking-wide flex items-center gap-2">
                                    <svg
                                        class="w-4 h-4"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479L11 12H4z"
                                        />
                                    </svg>
                                    Detalles del curso
                                </h3>
                                <div class="grid grid-cols-2 gap-4">
                                    {courseMeta.platform && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Plataforma:
                                            </span>
                                            <span class="font-medium text-text">
                                                {
                                                    courseMeta
                                                        .platform
                                                }
                                            </span>
                                        </div>
                                    )}
                                    {courseMeta
                                        .instructor && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Instructor:
                                            </span>
                                            <span class="font-medium text-text">
                                                {
                                                    courseMeta
                                                        .instructor
                                                }
                                            </span>
                                        </div>
                                    )}
                                    {courseMeta
                                        .durationMinutes && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Duración:
                                            </span>
                                            <span class="font-medium text-text">
                                                {formatDuration(
                                                    courseMeta
                                                        .durationMinutes,
                                                )}
                                            </span>
                                        </div>
                                    )}
                                    {courseMeta.level && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Nivel:
                                            </span>
                                            <span
                                                class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${
                                                    courseMeta
                                                        .level === "beginner"
                                                        ? "bg-emerald-500/20 text-emerald-300"
                                                        : (
                                                                courseMeta as CourseMetadata
                                                            ).level ===
                                                            "intermediate"
                                                          ? "bg-yellow-500/20 text-yellow-300"
                                                          : "bg-red-500/20 text-red-300"
                                                }`}
                                            >
                                                {
                                                    courseMeta
                                                        .level
                                                }
                                            </span>
                                        </div>
                                    )}
                                    {courseMeta.priceUsd !==
                                        undefined && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Precio:
                                            </span>
                                            <span class="font-medium text-text">
                                                {formatPrice(
                                                    courseMeta
                                                        .priceUsd,
                                                )}
                                            </span>
                                        </div>
                                    )}
                                    {courseMeta
                                        .modulesCount && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Módulos:
                                            </span>
                                            <span class="font-medium text-text">
                                                {
                                                    courseMeta
                                                        .modulesCount
                                                }
                                            </span>
                                        </div>
                                    )}
                                </div>
                                {courseMeta.syllabus &&
                                    courseMeta.syllabus!
                                        .length > 0 && (
                                        <div class="mt-4">
                                            <span class="text-sm text-text-muted block mb-2">
                                                Contenido del curso:
                                            </span>
                                            <ul class="space-y-1">
                                                {(
                                                    courseMeta as CourseMetadata
                                                ).syllabus!.map(
                                                    (item, index) => (
                                                        <li class="flex items-start gap-2 text-sm">
                                                            <span class="text-accent font-medium">
                                                                {index + 1}.
                                                            </span>
                                                            <span class="text-text">
                                                                {item}
                                                            </span>
                                                        </li>
                                                    ),
                                                )}
                                            </ul>
                                        </div>
                                    )}
                            </div>
                        )}

                        {resource.type === "podcast" && (
                            <div class="space-y-4">
                                <h3 class="text-sm font-semibold text-text uppercase tracking-wide flex items-center gap-2">
                                    <svg
                                        class="w-4 h-4"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0-11V4m0 11v4m0-11h4m-11 0h4m-4-11a3 3 0 01-3-3V4a3 3 0 013-3h4a3 3 0 013 3v3a3 3 0 01-3 3z"
                                        />
                                    </svg>
                                    Detalles del podcast
                                </h3>
                                <div class="grid grid-cols-2 gap-4">
                                    {podcastMeta.host && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Host:
                                            </span>
                                            <span class="font-medium text-text">
                                                {
                                                    (
                                                        podcastMeta as PodcastMetadata
                                                    ).host
                                                }
                                            </span>
                                        </div>
                                    )}
                                    {podcastMeta
                                        .episodeCount && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Episodios:
                                            </span>
                                            <span class="font-medium text-text">
                                                {
                                                    (
                                                        podcastMeta as PodcastMetadata
                                                    ).episodeCount
                                                }
                                            </span>
                                        </div>
                                    )}
                                    {podcastMeta
                                        .frequency && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Frecuencia:
                                            </span>
                                            <span class="font-medium text-text capitalize">
                                                {formatFrequency(
                                                    (
                                                        podcastMeta as PodcastMetadata
                                                    ).frequency!,
                                                )}
                                            </span>
                                        </div>
                                    )}
                                    {podcastMeta.platform && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Plataforma:
                                            </span>
                                            <span class="font-medium text-text">
                                                {
                                                    (
                                                        podcastMeta as PodcastMetadata
                                                    ).platform
                                                }
                                            </span>
                                        </div>
                                    )}
                                </div>
                                {podcastMeta.rssUrl && (
                                    <div class="flex items-center gap-2 text-sm mt-3">
                                        <span class="text-text-muted">
                                            RSS:
                                        </span>
                                        <a
                                            href={
                                                podcastMeta
                                                    .rssUrl
                                            }
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="text-accent hover:underline truncate"
                                        >
                                            {
                                                podcastMeta
                                                    .rssUrl
                                            }
                                        </a>
                                    </div>
                                )}
                            </div>
                        )}

                        {resource.type === "newsletter" && (
                            <div class="space-y-4">
                                <h3 class="text-sm font-semibold text-text uppercase tracking-wide flex items-center gap-2">
                                    <svg
                                        class="w-4 h-4"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                        />
                                    </svg>
                                    Detalles del newsletter
                                </h3>
                                <div class="grid grid-cols-2 gap-4">
                                    {newsletterMeta
                                        .author && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Autor:
                                            </span>
                                            <span class="font-medium text-text">
                                                {
                                                    (
                                                        newsletterMeta as NewsletterMetadata
                                                    ).author
                                                }
                                            </span>
                                        </div>
                                    )}
                                    {newsletterMeta
                                        .frequency && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Frecuencia:
                                            </span>
                                            <span class="font-medium text-text capitalize">
                                                {formatFrequency(
                                                    (
                                                        newsletterMeta as NewsletterMetadata
                                                    ).frequency!,
                                                )}
                                            </span>
                                        </div>
                                    )}
                                    {newsletterMeta
                                        .subscriberCount && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Suscriptores:
                                            </span>
                                            <span class="font-medium text-text">
                                                {formatCount(
                                                    (
                                                        newsletterMeta as NewsletterMetadata
                                                    ).subscriberCount,
                                                )}
                                            </span>
                                        </div>
                                    )}
                                    {newsletterMeta
                                        .platform && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Plataforma:
                                            </span>
                                            <span class="font-medium text-text">
                                                {
                                                    (
                                                        newsletterMeta as NewsletterMetadata
                                                    ).platform
                                                }
                                            </span>
                                        </div>
                                    )}
                                </div>
                                {newsletterMeta
                                    .archiveUrl && (
                                    <div class="flex items-center gap-2 text-sm mt-3">
                                        <span class="text-text-muted">
                                            Archivo:
                                        </span>
                                        <a
                                            href={
                                                newsletterMeta
                                                    .archiveUrl
                                            }
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="text-accent hover:underline truncate"
                                        >
                                            {
                                                newsletterMeta
                                                    .archiveUrl
                                            }
                                        </a>
                                    </div>
                                )}
                            </div>
                        )}

                        {resource.type === "community" && (
                            <div class="space-y-4">
                                <h3 class="text-sm font-semibold text-text uppercase tracking-wide flex items-center gap-2">
                                    <svg
                                        class="w-4 h-4"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                                        />
                                    </svg>
                                    Detalles de la comunidad
                                </h3>
                                <div class="grid grid-cols-2 gap-4">
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">
                                            Plataforma:
                                        </span>
                                        <span
                                            class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-accent/20 text-accent`}
                                        >
                                            {
                                                communityMeta
                                                    .platform
                                            }
                                        </span>
                                    </div>
                                    {communityMeta
                                        .memberCount && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Miembros:
                                            </span>
                                            <span class="font-medium text-text">
                                                {formatCount(
                                                    (
                                                        communityMeta as CommunityMetadata
                                                    ).memberCount,
                                                )}
                                            </span>
                                        </div>
                                    )}
                                    {communityMeta
                                        .isPrivate !== undefined && (
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-text-muted">
                                                Tipo:
                                            </span>
                                            <span
                                                class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${
                                                    (
                                                        communityMeta as CommunityMetadata
                                                    ).isPrivate
                                                        ? "bg-amber-500/20 text-amber-300"
                                                        : "bg-emerald-500/20 text-emerald-300"
                                                }`}
                                            >
                                                {communityMeta
                                                    .isPrivate
                                                    ? "Privada"
                                                    : "Pública"}
                                            </span>
                                        </div>
                                    )}
                                </div>
                                {communityMeta.inviteUrl && (
                                    <div class="flex items-center gap-2 text-sm mt-3">
                                        <span class="text-text-muted">
                                            Enlace de invitación:
                                        </span>
                                        <a
                                            href={
                                                communityMeta
                                                    .inviteUrl
                                            }
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="text-accent hover:underline truncate"
                                        >
                                            {
                                                communityMeta
                                                    .inviteUrl
                                            }
                                        </a>
                                    </div>
                                )}
                            </div>
                        )}
                    </div>
                )
            }

            <!-- Metadata section -->
            <div class="px-6 py-5 bg-overlay/50 border-t border-border">
                <div class="flex flex-wrap items-center gap-3">
                    <!-- Language badge -->
                    <span
                        class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium rounded border"
                        style={`background-color: oklch(${languageConfig.color} / 0.12); border-color: oklch(${languageConfig.color} / 0.30); color: oklch(${languageConfig.color});`}
                    >
                        <svg
                            class="w-3 h-3"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            {
                                resource.language === "ES" ? (
                                    <path d="M21 3H3v7l3 3 3-3 3 3 3-3 3 3V3zM3 14h18M3 18h18" />
                                ) : (
                                    <path d="M12 3v18M3 9h18M3 15h18" />
                                )
                            }
                        </svg>
                        {languageConfig.label}
                    </span>

                    <!-- Type badge -->
                    <span
                        class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs rounded border"
                        style={`background-color: oklch(${typeStyle.border} / 0.10); border-color: oklch(${typeStyle.border} / 0.30); color: oklch(${typeStyle.border});`}
                    >
                        <svg
                            class="w-3 h-3"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d={typeConfig.icon}></path>
                        </svg>
                        {typeConfig.label}
                    </span>

                    <!-- Category badge -->
                    {
                        categoryResult.ok && categoryResult.value && (
                            <CategoryBadge
                                name={categoryResult.value.name}
                                icon={categoryResult.value.icon}
                                size="md"
                            />
                        )
                    }

                    <!-- Tags -->
                    {
                        tags.length > 0 && (
                            <div class="flex flex-wrap gap-2 ml-auto">
                                {tags.map((tag: string) => (
                                    <span
                                        class="tag-chip px-2 py-0.5 text-xs rounded border text-text-subtle"
                                        style="background-color: oklch(0.28 0.04 235 / 0.08); border-color: oklch(0.28 0.04 235 / 0.15);"
                                    >
                                        #{tag}
                                    </span>
                                ))}
                            </div>
                        )
                    }
                </div>
            </div>

            {
                canEdit && (
                    <div class="px-6 py-4 border-t border-border flex items-center justify-between bg-surface">
                        <a
                            href={`/recursos/${resource.id}/edit`}
                            class="btn-press btn-shimmer px-5 py-2.5 bg-accent hover:bg-accent-hover text-bg text-sm font-medium rounded-lg transition-colors duration-150 flex items-center gap-2 shrink-0"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                                />
                            </svg>
                            Editar
                        </a>

                        <button
                            type="button"
                            id="detail-delete-btn"
                            data-resource-id={resource.id}
                            class="btn-press px-4 py-2 text-danger/70 hover:text-danger text-sm font-medium transition-colors duration-150 flex items-center gap-2 hover:bg-danger-bg/30 rounded-lg"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                                />
                            </svg>
                            Enviar a papelera
                        </button>
                    </div>
                )
            }
        </article>

        {
            canEdit && (
                <>
                    <ConfirmDialog
                        id="detail-delete-confirm"
                        title="Mover a papelera"
                        message="¿Querés mover este recurso a la papelera?"
                        confirmLabel="Mover a papelera"
                        cancelLabel="Cancelar"
                        variant="warning"
                    />
                    <ErrorModal id="detail-error-modal" />
                </>
            )
        }
    </div>
</Layout>

<script>
    import { authFetch } from "../../../lib/auth-interceptor";

    const btn = document.getElementById(
        "detail-delete-btn",
    ) as HTMLButtonElement | null;
    btn?.addEventListener("click", async () => {
        const id = btn.dataset.resourceId;
        if (!id) return;

        const confirmed = await (window as any).showConfirmDialog(
            "detail-delete-confirm",
        );
        if (!confirmed) return;

        const result = await authFetch(`/api/resources/${id}/delete`, {
            method: "POST",
            authContext: "Inicia sesión para mover el recurso a la papelera",
        });

        if (result.ok && result.value.ok) {
            window.location.href = "/recursos?deleted=true";
        } else {
            const msg = result.ok
                ? (await result.value.json().catch(() => ({}))).error
                : result.error.message;
            (window as any).showError(msg || "Error al eliminar");
        }
    });
</script>
