---
import Layout from "../../../layouts/Layout.astro";
import CategoryBadge from "../../../components/CategoryBadge.astro";
import {
    getResourceById,
    getCategoryById,
    parseTags,
} from "../../../lib/resources";
import {
    RESOURCE_TYPE_CONFIG,
    LANGUAGE_CONFIG,
} from "../../../lib/constants";
import {
    formatDuration,
    formatPrice,
    formatCount,
    formatFrequency,
    getExternalLinkLabel,
    type CourseMetadata,
    type PodcastMetadata,
    type NewsletterMetadata,
    type CommunityMetadata,
} from "../../../lib/metadata";

const { id } = Astro.params;
if (!id || isNaN(parseInt(id))) {
    return Astro.redirect("/recursos");
}
const resourceId = parseInt(id);

const resourceResult = getResourceById(resourceId);

if (!resourceResult.ok || !resourceResult.value) {
    return Astro.redirect("/recursos?error=not-found");
}

const resource = resourceResult.value;

if (resource.deletedAt) {
    return Astro.redirect("/recursos/trash");
}

const categoryResult = getCategoryById(resource.categoryId);
const tags = parseTags(resource.tags);

const languageConfig =
    LANGUAGE_CONFIG[resource.language as keyof typeof LANGUAGE_CONFIG] ??
    LANGUAGE_CONFIG.EN;
const typeConfig =
    RESOURCE_TYPE_CONFIG[resource.type as keyof typeof RESOURCE_TYPE_CONFIG] ??
    RESOURCE_TYPE_CONFIG.video;

// Type colors for visual distinction
const typeColors = {
    video:   { border: '0.60 0.18 25',   glow: '0.60 0.18 25'   },
    article: { border: '0.62 0.14 220',  glow: '0.62 0.14 220'  },
    tool:    { border: '0.64 0.12 155',  glow: '0.64 0.12 155'  },
    repo:    { border: '0.82 0.06 70',   glow: '0.82 0.06 70'   },
};

const typeStyle = typeColors[resource.type as keyof typeof typeColors] || typeColors.video;

const metadata = resource.metadata as Record<string, unknown> | null;
const externalLinkLabel = getExternalLinkLabel(resource.type, metadata);
---

<Layout
    title={`${resource.title} — Arsenal`}
    description={resource.description || `Recurso: ${resource.title}`}
>
    <div class="max-w-3xl mx-auto">
        <!-- Breadcrumb navigation -->
        <nav class="mb-8 flex items-center gap-2 text-sm animate-fade-left">
            <a
                href="/recursos"
                class="text-text-muted hover:text-text transition-colors duration-150 flex items-center gap-1.5 group"
            >
                <svg class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Recursos
            </a>
            <span class="text-text-subtle">/</span>
            <span class="text-text truncate max-w-50">{resource.title}</span>
        </nav>

        <!-- Main content card -->
        <article
            class="bg-surface border border-border rounded-2xl overflow-hidden animate-fade-up"
            style={`--type-border: oklch(${typeStyle.border}); --type-glow: oklch(${typeStyle.glow});`}
        >
            <!-- Header with accent line -->
            <div class="relative">
                <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-current to-transparent opacity-30" style={`color: oklch(${typeStyle.border});`}></div>
                <div class="p-6 pb-5">
                    <div class="flex items-start gap-5">
                        <!-- Type icon -->
                        <div
                            class="shrink-0 w-14 h-14 rounded-xl flex items-center justify-center border"
                            style={`background-color: oklch(${typeStyle.border} / 0.12); border-color: oklch(${typeStyle.border} / 0.30); color: oklch(${typeStyle.border});`}
                        >
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={typeConfig.icon}></path>
                            </svg>
                        </div>

                        <div class="flex-1 min-w-0">
                            <h1 class="text-2xl font-bold text-text tracking-tight leading-tight">
                                {resource.title}
                            </h1>
                            <a
                                href={resource.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-sm text-text-muted hover:text-accent transition-colors duration-150 flex items-center gap-2 mt-2 group/link"
                            >
                                <svg class="w-4 h-4 opacity-60 group-hover/link:opacity-100 group-hover/link:text-accent transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                                </svg>
                                <span class="truncate">{resource.url}</span>
                            </a>
                        </div>

                        <!-- Open link button -->
                        <a
                            href={resource.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="btn-press btn-shimmer px-5 py-2.5 bg-accent hover:bg-accent-hover text-bg text-sm font-medium rounded-xl transition-all duration-150 flex items-center gap-2 shadow-sm hover:shadow-glow-sm shrink-0"
                        >
                            {externalLinkLabel}
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Description -->
            {
                resource.description && (
                    <div class="px-6 py-5 border-t border-border">
                        <p class="text-text leading-relaxed">
                            {resource.description}
                        </p>
                    </div>
                )
            }

            {/* Type-specific metadata section */}
            {metadata && Object.keys(metadata).length > 0 && (
                <div class="px-6 py-5 border-t border-border bg-surface-subtle/30">
                    {resource.type === 'course' && (
                        <div class="space-y-4">
                            <h3 class="text-sm font-semibold text-text uppercase tracking-wide flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479L11 12H4z"></path>
                                </svg>
                                Detalles del curso
                            </h3>
                            <div class="grid grid-cols-2 gap-4">
                                {(metadata as CourseMetadata).platform && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Plataforma:</span>
                                        <span class="font-medium text-text">{(metadata as CourseMetadata).platform}</span>
                                    </div>
                                )}
                                {(metadata as CourseMetadata).instructor && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Instructor:</span>
                                        <span class="font-medium text-text">{(metadata as CourseMetadata).instructor}</span>
                                    </div>
                                )}
                                {(metadata as CourseMetadata).durationMinutes && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Duración:</span>
                                        <span class="font-medium text-text">{formatDuration((metadata as CourseMetadata).durationMinutes)}</span>
                                    </div>
                                )}
                                {(metadata as CourseMetadata).level && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Nivel:</span>
                                        <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${
                                            (metadata as CourseMetadata).level === 'beginner' ? 'bg-emerald-500/20 text-emerald-300' :
                                            (metadata as CourseMetadata).level === 'intermediate' ? 'bg-yellow-500/20 text-yellow-300' :
                                            'bg-red-500/20 text-red-300'
                                        }`}>
                                            {(metadata as CourseMetadata).level}
                                        </span>
                                    </div>
                                )}
                                {(metadata as CourseMetadata).priceUsd !== undefined && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Precio:</span>
                                        <span class="font-medium text-text">{formatPrice((metadata as CourseMetadata).priceUsd)}</span>
                                    </div>
                                )}
                                {(metadata as CourseMetadata).modulesCount && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Módulos:</span>
                                        <span class="font-medium text-text">{(metadata as CourseMetadata).modulesCount}</span>
                                    </div>
                                )}
                            </div>
                            {(metadata as CourseMetadata).syllabus && (metadata as CourseMetadata).syllabus!.length > 0 && (
                                <div class="mt-4">
                                    <span class="text-sm text-text-muted block mb-2">Contenido del curso:</span>
                                    <ul class="space-y-1">
                                        {(metadata as CourseMetadata).syllabus!.map((item, index) => (
                                            <li class="flex items-start gap-2 text-sm">
                                                <span class="text-accent font-medium">{index + 1}.</span>
                                                <span class="text-text">{item}</span>
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                            )}
                        </div>
                    )}

                    {resource.type === 'podcast' && (
                        <div class="space-y-4">
                            <h3 class="text-sm font-semibold text-text uppercase tracking-wide flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0-11V4m0 11v4m0-11h4m-11 0h4m-4-11a3 3 0 01-3-3V4a3 3 0 013-3h4a3 3 0 013 3v3a3 3 0 01-3 3z"></path>
                                </svg>
                                Detalles del podcast
                            </h3>
                            <div class="grid grid-cols-2 gap-4">
                                {(metadata as PodcastMetadata).host && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Host:</span>
                                        <span class="font-medium text-text">{(metadata as PodcastMetadata).host}</span>
                                    </div>
                                )}
                                {(metadata as PodcastMetadata).episodeCount && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Episodios:</span>
                                        <span class="font-medium text-text">{(metadata as PodcastMetadata).episodeCount}</span>
                                    </div>
                                )}
                                {(metadata as PodcastMetadata).frequency && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Frecuencia:</span>
                                        <span class="font-medium text-text capitalize">{formatFrequency((metadata as PodcastMetadata).frequency!)}</span>
                                    </div>
                                )}
                                {(metadata as PodcastMetadata).platform && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Plataforma:</span>
                                        <span class="font-medium text-text">{(metadata as PodcastMetadata).platform}</span>
                                    </div>
                                )}
                            </div>
                            {(metadata as PodcastMetadata).rssUrl && (
                                <div class="flex items-center gap-2 text-sm mt-3">
                                    <span class="text-text-muted">RSS:</span>
                                    <a href={(metadata as PodcastMetadata).rssUrl} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline truncate">
                                        {(metadata as PodcastMetadata).rssUrl}
                                    </a>
                                </div>
                            )}
                        </div>
                    )}

                    {resource.type === 'newsletter' && (
                        <div class="space-y-4">
                            <h3 class="text-sm font-semibold text-text uppercase tracking-wide flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                </svg>
                                Detalles del newsletter
                            </h3>
                            <div class="grid grid-cols-2 gap-4">
                                {(metadata as NewsletterMetadata).author && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Autor:</span>
                                        <span class="font-medium text-text">{(metadata as NewsletterMetadata).author}</span>
                                    </div>
                                )}
                                {(metadata as NewsletterMetadata).frequency && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Frecuencia:</span>
                                        <span class="font-medium text-text capitalize">{formatFrequency((metadata as NewsletterMetadata).frequency!)}</span>
                                    </div>
                                )}
                                {(metadata as NewsletterMetadata).subscriberCount && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Suscriptores:</span>
                                        <span class="font-medium text-text">{formatCount((metadata as NewsletterMetadata).subscriberCount)}</span>
                                    </div>
                                )}
                                {(metadata as NewsletterMetadata).platform && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Plataforma:</span>
                                        <span class="font-medium text-text">{(metadata as NewsletterMetadata).platform}</span>
                                    </div>
                                )}
                            </div>
                            {(metadata as NewsletterMetadata).archiveUrl && (
                                <div class="flex items-center gap-2 text-sm mt-3">
                                    <span class="text-text-muted">Archivo:</span>
                                    <a href={(metadata as NewsletterMetadata).archiveUrl} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline truncate">
                                        {(metadata as NewsletterMetadata).archiveUrl}
                                    </a>
                                </div>
                            )}
                        </div>
                    )}

                    {resource.type === 'community' && (
                        <div class="space-y-4">
                            <h3 class="text-sm font-semibold text-text uppercase tracking-wide flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                </svg>
                                Detalles de la comunidad
                            </h3>
                            <div class="grid grid-cols-2 gap-4">
                                <div class="flex items-center gap-2 text-sm">
                                    <span class="text-text-muted">Plataforma:</span>
                                    <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-accent/20 text-accent`}>
                                        {(metadata as CommunityMetadata).platform}
                                    </span>
                                </div>
                                {(metadata as CommunityMetadata).memberCount && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Miembros:</span>
                                        <span class="font-medium text-text">{formatCount((metadata as CommunityMetadata).memberCount)}</span>
                                    </div>
                                )}
                                {(metadata as CommunityMetadata).isPrivate !== undefined && (
                                    <div class="flex items-center gap-2 text-sm">
                                        <span class="text-text-muted">Tipo:</span>
                                        <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${
                                            (metadata as CommunityMetadata).isPrivate
                                                ? 'bg-amber-500/20 text-amber-300'
                                                : 'bg-emerald-500/20 text-emerald-300'
                                        }`}>
                                            {(metadata as CommunityMetadata).isPrivate ? 'Privada' : 'Pública'}
                                        </span>
                                    </div>
                                )}
                            </div>
                            {(metadata as CommunityMetadata).inviteUrl && (
                                <div class="flex items-center gap-2 text-sm mt-3">
                                    <span class="text-text-muted">Enlace de invitación:</span>
                                    <a href={(metadata as CommunityMetadata).inviteUrl} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline truncate">
                                        {(metadata as CommunityMetadata).inviteUrl}
                                    </a>
                                </div>
                            )}
                        </div>
                    )}
                </div>
            )}

            <!-- Metadata section -->
            <div class="px-6 py-5 bg-overlay/50 border-t border-border">
                <div class="flex flex-wrap items-center gap-3">
                    <!-- Language badge -->
                    <span
                        class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium rounded border"
                        style={`background-color: oklch(${languageConfig.color} / 0.12); border-color: oklch(${languageConfig.color} / 0.30); color: oklch(${languageConfig.color});`}
                    >
                        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            {resource.language === 'ES' ? (
                                <path d="M21 3H3v7l3 3 3-3 3 3 3-3 3 3V3zM3 14h18M3 18h18" />
                            ) : (
                                <path d="M12 3v18M3 9h18M3 15h18" />
                            )}
                        </svg>
                        {languageConfig.label}
                    </span>

                    <!-- Type badge -->
                    <span
                        class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs rounded border"
                        style={`background-color: oklch(${typeStyle.border} / 0.10); border-color: oklch(${typeStyle.border} / 0.30); color: oklch(${typeStyle.border});`}
                    >
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={typeConfig.icon}></path>
                        </svg>
                        {typeConfig.label}
                    </span>

                    <!-- Category badge -->
                    {
                        categoryResult.ok && categoryResult.value && (
                            <CategoryBadge
                                name={categoryResult.value.name}
                                icon={categoryResult.value.icon}
                                size="md"
                            />
                        )
                    }

                    <!-- Tags -->
                    {
                        tags.length > 0 && (
                            <div class="flex flex-wrap gap-2 ml-auto">
                                {tags.map((tag: string) => (
                                    <span
                                        class="tag-chip px-2 py-0.5 text-xs rounded border text-text-subtle"
                                        style="background-color: oklch(0.28 0.04 235 / 0.08); border-color: oklch(0.28 0.04 235 / 0.15);"
                                    >
                                        #{tag}
                                    </span>
                                ))}
                            </div>
                        )
                    }
                </div>
            </div>

            <!-- Actions -->
            <div
                class="px-6 py-4 border-t border-border flex items-center justify-between bg-surface"
            >
                        <a
                            href={`/recursos/${resource.id}/edit`}
                            class="btn-press btn-shimmer px-5 py-2.5 bg-accent hover:bg-accent-hover text-bg text-sm font-medium rounded-lg transition-colors duration-150 flex items-center gap-2 shrink-0"
                        >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                    Editar
                </a>

                <form
                    method="POST"
                    action={`/recursos/${resource.id}/delete`}
                    class="flex items-center gap-3"
                >
                    <button
                        type="submit"
                        class="btn-press px-4 py-2 text-danger/70 hover:text-danger text-sm font-medium transition-colors duration-150 flex items-center gap-2 hover:bg-danger-bg/30 rounded-lg"
                    >
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                        Enviar a papelera
                    </button>
                </form>
            </div>
        </article>
    </div>
</Layout>
