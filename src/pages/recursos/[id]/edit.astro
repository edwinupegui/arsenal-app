---
import Layout from "../../../layouts/Layout.astro";
import ResourceForm from "../../../components/ResourceForm.astro";
import ConfirmDialog from "../../../components/ConfirmDialog.astro";
import {
    getResourceById,
    listCategories,
    parseTags,
    resourceService,
} from "../../../lib/resources";
import { isOk } from "../../../lib/result";

const { id } = Astro.params;
if (!id || isNaN(parseInt(id))) {
    return Astro.redirect("/recursos");
}
const resourceId = parseInt(id);

const resourceResult = getResourceById(resourceId);

if (
    !resourceResult.ok ||
    !resourceResult.value ||
    resourceResult.value.deletedAt
) {
    return Astro.redirect("/recursos?error=not-found");
}

const resource = resourceResult.value;

const categoriesResult = listCategories();
const categories = categoriesResult.ok ? categoriesResult.value : [];

if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();

        const title = formData.get("title") as string;
        const url = formData.get("url") as string;
        const description = formData.get("description") as string;
        const tagsRaw = formData.get("tags") as string;
        const language = formData.get("language") as string;
        const type = formData.get("type") as string;
        const categoryId = parseInt(formData.get("categoryId") as string);

        const tags = tagsRaw
            ? tagsRaw
                  .split(",")
                  .map((t) => t.trim())
                  .filter(Boolean)
            : [];

        const result = resourceService.updateResource(resourceId, {
            title,
            url,
            description,
            tags,
            language,
            type,
            categoryId,
        });

        if (isOk(result)) {
            return Astro.redirect(`/recursos?updated=true`);
        } else {
            return Astro.redirect(
                `/recursos/${resourceId}/edit?error=${encodeURIComponent(result.error.message)}`,
            );
        }
    } catch (e) {
        return Astro.redirect(
            `/recursos/${resourceId}/edit?error=Error+inesperado`,
        );
    }
}

const resourceData = {
    ...resource,
    tags: parseTags(resource.tags),
};
---

<Layout title={`Editar: ${resource.title} — Arsenal`}>
    <div class="max-w-2xl mx-auto">
        <div class="mb-6">
            <a
                href={`/recursos/${resourceId}`}
                class="inline-flex items-center gap-2 text-text-muted hover:text-text transition-colors duration-150 group"
            >
                <svg class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                <span class="text-sm">Volver al recurso</span>
            </a>
        </div>

        <div class="mb-8">
            <h1 class="text-2xl font-bold text-text tracking-tight">
                Editar Recurso
            </h1>
            <p class="text-text-muted mt-1">
                Modifica los datos del recurso
            </p>
        </div>

        <div class="bg-surface border border-border rounded-xl p-6">
            <ResourceForm
                action="edit"
                initialData={resourceData}
                categories={categories}
            />
        </div>

        <ConfirmDialog
            id="edit-confirm"
            title="Guardar cambios"
            message="¿Estás seguro de que quieres guardar los cambios?"
            confirmLabel="Guardar"
            cancelLabel="Cancelar"
        />
    </div>
</Layout>
