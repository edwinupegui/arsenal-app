---
import Layout from "../../../layouts/Layout.astro";
import ResourceForm from "../../../components/ResourceForm.astro";
import ConfirmDialog from "../../../components/ConfirmDialog.astro";
import ErrorModal from "../../../components/ErrorModal.astro";
import {
    getResourceById,
    listCategories,
    parseTags,
} from "../../../lib/resources";

const { id } = Astro.params;
if (!id || isNaN(parseInt(id))) {
    return Astro.redirect("/recursos");
}
const resourceId = parseInt(id);

const resourceResult = getResourceById(resourceId);

if (
    !resourceResult.ok ||
    !resourceResult.value ||
    resourceResult.value.deletedAt
) {
    return Astro.redirect("/recursos?error=not-found");
}

const resource = resourceResult.value;

const categoriesResult = listCategories();
const categories = categoriesResult.ok ? categoriesResult.value : [];

const resourceData = {
    ...resource,
    tags: parseTags(resource.tags),
};
---

<Layout title={`Editar: ${resource.title} — Arsenal`}>
    <div class="max-w-2xl mx-auto">
        <div class="mb-6">
            <a
                href={`/recursos/${resourceId}`}
                class="inline-flex items-center gap-2 text-text-muted hover:text-text transition-colors duration-150 group"
            >
                <svg class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                <span class="text-sm">Volver al recurso</span>
            </a>
        </div>

        <div class="mb-8">
            <h1 class="text-2xl font-bold text-text tracking-tight">
                Editar Recurso
            </h1>
            <p class="text-text-muted mt-1">
                Modifica los datos del recurso
            </p>
        </div>

        <div class="bg-surface border border-border rounded-xl p-6">
            <ResourceForm
                action="edit"
                initialData={resourceData}
                categories={categories}
            />
        </div>

        <input type="hidden" id="resource-id-data" value={resourceId} />


        <ConfirmDialog
            id="edit-confirm"
            title="Guardar cambios"
            message="¿Estás seguro de que quieres guardar los cambios?"
            confirmLabel="Guardar"
            cancelLabel="Cancelar"
            variant="info"
        />

        <ErrorModal id="edit-error-modal" />
    </div>
</Layout>

<script>
    import { authFetch } from "../../../lib/auth-interceptor";

    const form = document.getElementById('resource-form') as HTMLFormElement;
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const confirmed = await (window as any).showConfirmDialog('edit-confirm');
        if (!confirmed) return;

        const formData = new FormData(form);
        const data: Record<string, unknown> = {};
        formData.forEach((value, key) => {
            if (key === 'categoryId' || key === 'metadata') {
                // Skip, handled separately
            } else {
                data[key] = value;
            }
        });
        data.categoryId = parseInt(formData.get('categoryId') as string);
        data.tags = (formData.get('tags') as string)
            ? (formData.get('tags') as string).split(',').map(t => t.trim()).filter(Boolean)
            : [];

        const metadataValue = formData.get('metadata');
        if (metadataValue && (metadataValue as string).trim()) {
            try {
                data.metadata = JSON.parse(metadataValue as string);
            } catch {
                data.metadata = {};
            }
        }

        const idEl = document.getElementById('resource-id-data') as HTMLInputElement | null;
        const resourceId = idEl?.value;
        if (!resourceId) {
            (window as any).showError('No se pudo determinar el id del recurso');
            return;
        }

        const result = await authFetch(`/api/resources/${resourceId}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data),
            authContext: 'Inicia sesión para guardar los cambios',
        });

        if (result.ok) {
            const response = result.value;
            if (response.ok) {
                window.location.href = '/recursos?updated=true';
            } else {
                const result_data = await response.json();
                (window as any).showError(result_data.error || 'Error al guardar');
            }
        } else {
            (window as any).showError(result.error.message || 'Error de autenticación');
        }
    });
</script>
