---
import Layout from "../../../layouts/Layout.astro";
import ConfirmDialog from "../../../components/ConfirmDialog.astro";
import ErrorModal from "../../../components/ErrorModal.astro";
import {
    getResourceById,
    parseTags,
} from "../../../lib/resources";

const { id } = Astro.params;
if (!id || isNaN(parseInt(id))) {
    return Astro.redirect("/recursos?error=invalid-id");
}
const resourceId = parseInt(id);

const resourceResult = getResourceById(resourceId);

if (
    !resourceResult.ok ||
    !resourceResult.value ||
    resourceResult.value.deletedAt
) {
    return Astro.redirect("/recursos?error=not-found");
}

const resource = resourceResult.value;
const resourceData = {
    ...resource,
    tags: parseTags(resource.tags),
};
---

<Layout title={`Eliminar: ${resource.title} — Arsenal`}>
    <div class="max-w-lg mx-auto">
        <div class="mb-6">
            <a
                href={`/recursos/${resourceId}`}
                class="inline-flex items-center gap-2 text-text-muted hover:text-text transition-colors duration-150 group"
            >
                <svg class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                <span class="text-sm">Volver al recurso</span>
            </a>
        </div>

        <div class="bg-surface border border-border rounded-xl p-6">
            <h1 class="text-xl font-bold text-text mb-2">Eliminar recurso</h1>
            <p class="text-text-muted mb-6">
                ¿Estás seguro de que quieres eliminar <strong class="text-text">{resource.title}</strong>?
                El recurso se moverá a la papelera.
            </p>

            <form
                id="delete-form"
                method="POST"
                action={`/api/resources/${resourceId}/delete`}
                class="flex gap-3 justify-end"
            >
                <a
                    href={`/recursos/${resourceId}`}
                    class="px-4 py-2 bg-surface-elevated hover:bg-overlay border border-border text-text text-sm rounded-lg transition-all duration-150"
                >
                    Cancelar
                </a>
                <button
                    type="submit"
                    class="btn-press px-4 py-2 bg-danger hover:bg-danger/80 text-white text-sm font-medium rounded-lg transition-all duration-150"
                >
                    Eliminar
                </button>
            </form>
        </div>

        <ConfirmDialog
            id="delete-confirm"
            title="Eliminar recurso"
            message="¿Estás seguro de que quieres eliminar este recurso? Podrás restaurarlo desde la papelera."
            confirmLabel="Eliminar"
            cancelLabel="Cancelar"
        />

        <ErrorModal id="delete-error-modal" />
    </div>
</Layout>

<script>
    const form = document.getElementById('delete-form') as HTMLFormElement;
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const confirmed = await (window as any).showConfirmDialog('delete-confirm');
        if (!confirmed) return;

        const response = await fetch(form.action, {
            method: 'POST',
            credentials: 'include',
        });

        if (response.ok) {
            window.location.href = '/recursos?deleted=true';
        } else {
            const data = await response.json();
            (window as any).showError(data.error || 'Error al eliminar');
        }
    });
</script>