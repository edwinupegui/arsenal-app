# Arsenal - Environment Variables
# Copy this file to .env and fill in the values if needed.

# Database (defaults to local SQLite file)
# DATABASE_URL=./resources.db

# Admin Authentication (Session-based, HMAC-signed cookie)
# Required for creating, editing, and deleting resources via API
# Without these, login will fail and all mutating API requests will be rejected
ADMIN_USER="admin"
ADMIN_PASSWORD="your-secure-password-here"

# Session signing secret — HMAC-SHA256, 32+ chars. Generate: openssl rand -hex 32
SESSION_SECRET="replace-with-random-32-byte-hex"
